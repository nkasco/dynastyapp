NEXT_PUBLIC_APP_NAME="Dynalytics"

# Required in production. Generate with: openssl rand -base64 32
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""
LOCAL_AUTH_ENABLED="true"

# Optional idempotent bootstrap inputs for `pnpm db:bootstrap`.
FIRST_ADMIN_EMAIL=""
FIRST_ADMIN_NAME="League Admin"
FIRST_ADMIN_PASSWORD=""
FIRST_ADMIN_PASSWORD_HASH=""
BOOTSTRAP_INVITE_CODES=""

DATABASE_URL="file:./data/dynalytics.db"
DATABASE_PATH="./data/dynalytics.db"

IMPORT_TIME_ZONE="America/New_York"
IMPORT_NIGHTLY_CRON="0 1 * * *"
SLEEPER_BASE_URL="https://api.sleeper.app/v1"
NFLVERSE_BASE_URL="https://github.com/nflverse/nflverse-data/releases/download"
